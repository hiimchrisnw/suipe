{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded",
      "quoteStyle": "double",
      "trailingCommas": "all"
    }
  },
  "css": {
    "parser": { "cssModules": false, "tailwindDirectives": true }
  },
  "files": {
    "includes": ["**", "!**/node_modules", "!**/dist", "!**/.wrangler", "!**/*.d.ts"]
  }
}
